# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_OUTAGE_TOPIC=outage.events
KAFKA_NOTIFICATION_TOPIC=notification.events
KAFKA_BILLING_TOPIC=billing.events
KAFKA_ANALYTICS_TOPIC=analytics.events
KAFKA_RETRY_TOPIC=outage.events.retry

# Redis
REDIS_CONNECTION=localhost:6379
REDIS_PREFIX=mcp:outage

# App defaults
MCP_SCHEMA_VERSION=1.0.0
ASPNETCORE_ENVIRONMENT=Development
